#!/bin/bash

# Swarmnero Pre-commit Security Hook
# Prevents commits containing sensitive files or secrets

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

echo "Running security scan..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

BLOCKED=0

# === CHECK 1: Sensitive file patterns ===
SENSITIVE_PATTERNS=(
    "identity.json"
    "*.pem"
    "*.key"
    "*.p12"
    "*.pfx"
    ".env"
    ".env.*"
    "*.secret"
    "credentials.json"
    "secrets.json"
    "wallet.json"
    "*.wallet"
    "monero-wallet*"
)

for file in $STAGED_FILES; do
    filename=$(basename "$file")
    for pattern in "${SENSITIVE_PATTERNS[@]}"; do
        if [[ "$filename" == $pattern ]]; then
            echo -e "${RED}BLOCKED:${NC} Sensitive file detected: $file"
            BLOCKED=1
        fi
    done
done

# === CHECK 2: Scan for hardcoded secrets ===
for file in $STAGED_FILES; do
    # Skip binary files
    if file "$file" 2>/dev/null | grep -q "binary"; then
        continue
    fi

    CONTENT=$(git show ":$file" 2>/dev/null)

    # Private keys (actual PEM format with dashes)
    if echo "$CONTENT" | grep -qE "^\-\-\-\-\-BEGIN.*(PRIVATE|RSA|EC)"; then
        echo -e "${RED}BLOCKED:${NC} Private key found in: $file"
        BLOCKED=1
    fi

    # API keys / tokens
    if echo "$CONTENT" | grep -qiE "(api_key|apikey|secret_key|auth_token)['\"]?\s*[:=]\s*['\"][a-zA-Z0-9]{16,}"; then
        echo -e "${RED}BLOCKED:${NC} Potential API key in: $file"
        BLOCKED=1
    fi

    # AWS keys
    if echo "$CONTENT" | grep -qE "AKIA[0-9A-Z]{16}"; then
        echo -e "${RED}BLOCKED:${NC} AWS key found in: $file"
        BLOCKED=1
    fi

    # Monero keys (64 hex after key identifier)
    if echo "$CONTENT" | grep -qE "(spend_key|view_key|secretKey)[^a-fA-F0-9]*[0-9a-fA-F]{64}"; then
        echo -e "${RED}BLOCKED:${NC} Potential Monero key in: $file"
        BLOCKED=1
    fi
done

# === CHECK 3: Large files warning ===
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        SIZE=$(wc -c < "$file" | tr -d ' ')
        if [ "$SIZE" -gt 1048576 ]; then
            echo -e "${YELLOW}WARNING:${NC} Large file: $file (${SIZE} bytes)"
        fi
    fi
done

# === RESULT ===
if [ "$BLOCKED" -eq 1 ]; then
    echo ""
    echo -e "${RED}Commit blocked due to security issues.${NC}"
    echo "To bypass (use with caution): git commit --no-verify"
    exit 1
fi

echo -e "${GREEN}Security scan passed.${NC}"
exit 0
